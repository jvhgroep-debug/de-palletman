---
interface Region {
  name: string;
  text: string;
  href?: string;
}

interface Props {
  regions: Region[];
}

const { regions } = Astro.props;
---

<section class="page-regions" aria-label="Werkgebied per provincie">
  <div class="page-regions__inner container">
    <ul class="page-regions__grid">
      {
        regions.map((region) => (
          <li class="page-regions__item">
            {
              region.href ? (
                <a href={region.href} class="page-regions__link">
                  <h3 class="page-regions__name">{region.name}</h3>
                  <p class="page-regions__text">{region.text}</p>
                  <span class="page-regions__cta">
                    Bekijk {region.name}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path
                        d="M5 12h14M13 6l6 6-6 6"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </span>
                </a>
              ) : (
                <>
                  <h3 class="page-regions__name">{region.name}</h3>
                  <p class="page-regions__text">{region.text}</p>
                </>
              )
            }
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .page-regions {
    padding-block: var(--space-2xl) var(--space-3xl);
    background-color: var(--color-gray-50);
  }

  .page-regions__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  .page-regions__item {
    padding: 0;
    background-color: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    border-top: 4px solid var(--color-gold);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  .page-regions__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--space-xl);
    color: inherit;
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }

  .page-regions__link:hover {
    background-color: var(--color-gray-50);
  }

  .page-regions__link:hover .page-regions__cta {
    color: var(--color-blue);
    gap: var(--space-md);
  }

  .page-regions__name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: var(--space-sm);
  }

  .page-regions__text {
    flex: 1;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-gray-600);
    margin-bottom: var(--space-md);
  }

  .page-regions__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-top: auto;
    transition: color var(--transition-fast), gap var(--transition-fast);
  }

  @media (min-width: 640px) {
    .page-regions__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .page-regions__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
