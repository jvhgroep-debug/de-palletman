---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  eyebrow?: string;
  title?: string;
  intro?: string;
  id?: string;
  variant?: "gray" | "white";
}

const { items, eyebrow, title, intro, id, variant = "gray" } = Astro.props;
---

<section
  class:list={["page-faq", variant === "white" && "page-faq--white"]}
  aria-labelledby={id}
>
  <div class="page-faq__inner container">
    {
      (eyebrow || title || intro) && (
        <header class="page-faq__header">
          {eyebrow && <p class="page-faq__eyebrow">{eyebrow}</p>}
          {title && (
            <h2 id={id} class="page-faq__title">
              {title}
            </h2>
          )}
          {intro && <p class="page-faq__intro">{intro}</p>}
        </header>
      )
    }
    <dl class="page-faq__list">
      {
        items.map((item) => (
          <div class="page-faq__item">
            <dt class="page-faq__question">{item.question}</dt>
            <dd class="page-faq__answer">{item.answer}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .page-faq {
    padding-block: var(--space-2xl) var(--space-3xl);
    background-color: var(--color-gray-50);
  }

  .page-faq--white {
    background-color: var(--color-white);
  }

  .page-faq__header {
    max-width: 720px;
    margin-bottom: var(--space-2xl);
  }

  .page-faq__eyebrow {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-blue);
    margin-bottom: var(--space-sm);
  }

  .page-faq__title {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 800;
    color: var(--color-navy);
    line-height: 1.25;
    margin-bottom: var(--space-md);
  }

  .page-faq__intro {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-gray-600);
  }

  .page-faq__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 800px;
  }

  .page-faq__item {
    padding: var(--space-lg) var(--space-xl);
    background-color: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--color-gold);
  }

  .page-faq--white .page-faq__item {
    background-color: var(--color-gray-50);
  }

  .page-faq__question {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: var(--space-sm);
    line-height: 1.4;
  }

  .page-faq__answer {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-gray-600);
    margin: 0;
  }
</style>
