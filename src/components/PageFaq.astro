---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<section class="page-faq" aria-label="Veelgestelde vragen">
  <div class="page-faq__inner container">
    <dl class="page-faq__list">
      {
        items.map((item) => (
          <div class="page-faq__item">
            <dt class="page-faq__question">{item.question}</dt>
            <dd class="page-faq__answer">{item.answer}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .page-faq {
    padding-block: var(--space-2xl) var(--space-3xl);
    background-color: var(--color-gray-50);
  }

  .page-faq__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 800px;
  }

  .page-faq__item {
    padding: var(--space-lg) var(--space-xl);
    background-color: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--color-gold);
  }

  .page-faq__question {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: var(--space-sm);
    line-height: 1.4;
  }

  .page-faq__answer {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-gray-600);
    margin: 0;
  }
</style>
