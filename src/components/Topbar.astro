---
const usps = [
  "Inkoop & verkoop gebruikte pallets",
  "Snelle service door heel Nederland",
  "Duurzaam, betrouwbaar & voordelig",
];
---

<div class="topbar">
  <div class="topbar__inner container">
    <ul class="topbar__usps" aria-label="Unique selling points">
      {
        usps.map((usp) => (
          <li class="topbar__usp">
            <svg
              class="topbar__check"
              width="14"
              height="14"
              viewBox="0 0 14 14"
              fill="none"
              aria-hidden="true"
            >
              <circle cx="7" cy="7" r="7" fill="currentColor" />
              <path
                d="M4 7L6 9L10 5"
                stroke="#0b1d35"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            <span>{usp}</span>
          </li>
        ))
      }
    </ul>

    <a href="tel:+31612345678" class="topbar__phone">
      <svg
        class="topbar__phone-icon"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
      <span>Bel direct: <strong>06 12 34 56 78</strong></span>
    </a>
  </div>
</div>

<style>
  .topbar {
    background-color: var(--color-navy);
    color: var(--color-white);
    font-size: 0.8125rem;
    font-weight: 500;
    min-height: var(--topbar-height);
    display: flex;
    align-items: center;
  }

  .topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    width: 100%;
    min-height: var(--topbar-height);
    padding-block: var(--space-sm);
  }

  .topbar__usps {
    display: none;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .topbar__usp {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    white-space: nowrap;
  }

  .topbar__check {
    flex-shrink: 0;
    color: var(--color-gold);
  }

  .topbar__phone {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-white);
    transition: color var(--transition-fast);
    margin-left: auto;
    white-space: nowrap;
  }

  .topbar__phone:hover {
    color: var(--color-gold);
  }

  .topbar__phone-icon {
    flex-shrink: 0;
    color: var(--color-gold);
  }

  .topbar__phone strong {
    font-weight: 700;
  }

  @media (min-width: 768px) {
    .topbar__usps {
      display: flex;
    }

    .topbar__phone {
      margin-left: 0;
    }
  }

  @media (min-width: 1024px) {
    .topbar__usps {
      gap: var(--space-xl);
    }
  }
</style>
