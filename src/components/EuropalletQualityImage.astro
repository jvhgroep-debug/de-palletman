---
import {
  type EuropalletQualityGrade,
  getEuropalletQualityImage,
} from "../content/shared/europalletQuality";

interface Props {
  quality: EuropalletQualityGrade;
  aspectRatio?: string;
  class?: string;
  loading?: "lazy" | "eager";
}

const {
  quality,
  aspectRatio = "4 / 3",
  class: className,
  loading = "lazy",
} = Astro.props;

const image = getEuropalletQualityImage(quality);
---

<div
  class:list={["europallet-quality-image", className]}
  style={`--europallet-quality-ratio: ${aspectRatio}`}
>
  <img
    class="europallet-quality-image__img"
    src={image.src}
    alt={image.alt}
    width={image.width}
    height={image.height}
    loading={loading}
    decoding="async"
  />
</div>

<style>
  .europallet-quality-image {
    position: relative;
    width: 100%;
    aspect-ratio: var(--europallet-quality-ratio);
    min-height: 200px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: linear-gradient(
      145deg,
      var(--color-gray-100) 0%,
      var(--color-gray-50) 50%,
      var(--color-gray-100) 100%
    );
  }

  .europallet-quality-image__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
</style>
