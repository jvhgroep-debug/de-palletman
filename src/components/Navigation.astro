---
interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const navItems = [
  { label: "Home", href: "/" },
  { label: "Pallets verkopen", href: "/pallets-verkopen" },
  { label: "Pallets kopen", href: "/pallets-kopen" },
  { label: "Particulier", href: "/pallets-verkopen" },
  { label: "Over ons", href: "/over-ons" },
  { label: "Contact", href: "/contact" },
];
---

<nav class="navigation" aria-label="Hoofdnavigatie">
  <button
    class="navigation__toggle"
    type="button"
    aria-expanded="false"
    aria-controls="main-nav-menu"
    aria-label="Menu openen"
  >
    <span class="navigation__toggle-bar"></span>
    <span class="navigation__toggle-bar"></span>
    <span class="navigation__toggle-bar"></span>
  </button>

  <div class="navigation__panel" id="main-nav-menu">
    <ul class="navigation__list">
      {
        navItems.map((item) => (
          <li class="navigation__item">
            <a
              href={item.href}
              class:list={[
                "navigation__link",
                { "navigation__link--active": currentPath === item.href },
              ]}
              aria-current={currentPath === item.href ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="navigation__mobile-actions">
      <a href="/contact" class="navigation__mobile-cta">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          />
        </svg>
        Vraag een prijs aan
      </a>
    </div>
  </div>
</nav>

<script>
  function initNavigation() {
    const toggle = document.querySelector(".navigation__toggle");
    const panel = document.querySelector(".navigation__panel");

    if (!toggle || !panel) return;

    const closeMenu = () => {
      toggle.setAttribute("aria-expanded", "false");
      toggle.setAttribute("aria-label", "Menu openen");
      panel.classList.remove("navigation__panel--open");
      document.body.classList.remove("nav-open");
    };

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!isOpen));
      toggle.setAttribute("aria-label", isOpen ? "Menu openen" : "Menu sluiten");
      panel.classList.toggle("navigation__panel--open", !isOpen);
      document.body.classList.toggle("nav-open", !isOpen);
    });

    panel.querySelectorAll(".navigation__link").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1024) closeMenu();
    });
  }

  initNavigation();
  document.addEventListener("astro:page-load", initNavigation);
</script>

<style>
  .navigation {
    position: relative;
  }

  .navigation__toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    border-radius: var(--radius-sm);
    transition: background-color var(--transition-fast);
  }

  .navigation__toggle:hover {
    background-color: var(--color-gray-100);
  }

  .navigation__toggle-bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-navy);
    border-radius: 2px;
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .navigation__toggle[aria-expanded="true"] .navigation__toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .navigation__toggle[aria-expanded="true"] .navigation__toggle-bar:nth-child(2) {
    opacity: 0;
  }

  .navigation__toggle[aria-expanded="true"] .navigation__toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .navigation__panel {
    position: fixed;
    inset: 0;
    top: calc(var(--topbar-height) + var(--header-height));
    background-color: var(--color-white);
    padding: var(--space-xl) var(--space-lg);
    transform: translateX(100%);
    transition: transform var(--transition-base);
    z-index: 100;
    overflow-y: auto;
    box-shadow: var(--shadow-lg);
  }

  .navigation__panel--open {
    transform: translateX(0);
  }

  .navigation__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .navigation__link {
    display: block;
    padding: var(--space-md) var(--space-sm);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-navy);
    border-bottom: 3px solid transparent;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .navigation__link:hover {
    color: var(--color-blue);
  }

  .navigation__link--active {
    color: var(--color-navy);
    border-bottom-color: var(--color-blue);
  }

  .navigation__mobile-actions {
    margin-top: var(--space-xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-gray-200);
  }

  .navigation__mobile-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    width: 100%;
    padding: var(--space-md) var(--space-lg);
    background-color: var(--color-gold);
    color: var(--color-navy);
    font-weight: 700;
    font-size: 0.9375rem;
    border-radius: var(--radius-md);
    transition: background-color var(--transition-fast);
  }

  .navigation__mobile-cta:hover {
    background-color: var(--color-gold-hover);
  }

  @media (min-width: 1024px) {
    .navigation__toggle {
      display: none;
    }

    .navigation__panel {
      position: static;
      inset: auto;
      padding: 0;
      transform: none;
      overflow: visible;
      box-shadow: none;
      background: transparent;
    }

    .navigation__list {
      flex-direction: row;
      align-items: center;
      gap: var(--space-xs);
    }

    .navigation__link {
      padding: var(--space-sm) var(--space-md);
      font-size: 0.875rem;
      white-space: nowrap;
    }

    .navigation__mobile-actions {
      display: none;
    }
  }

  @media (min-width: 1280px) {
    .navigation__list {
      gap: var(--space-sm);
    }

    .navigation__link {
      font-size: 0.9375rem;
      padding: var(--space-sm) var(--space-md);
    }
  }
</style>

<style is:global>
  body.nav-open {
    overflow: hidden;
  }
</style>
