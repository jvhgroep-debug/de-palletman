---
interface Props {
  filename: string;
  aspectRatio?: string;
  class?: string;
}

const { filename, aspectRatio = "4 / 3", class: className } = Astro.props;
---

<div
  class:list={["image-placeholder", className]}
  style={`--placeholder-ratio: ${aspectRatio}`}
  role="img"
  aria-label={`Plaats hier: ${filename}`}
>
  <!--
    Vervang deze placeholder door:
    <img src="/images/{filename}" alt="..." class="..." loading="lazy" decoding="async" />
  -->
  <div class="image-placeholder__inner">
    <span class="image-placeholder__line" aria-hidden="true"></span>
    <p class="image-placeholder__heading">PLAATS HIER:</p>
    <p class="image-placeholder__filename">{filename}</p>
    <span class="image-placeholder__line" aria-hidden="true"></span>
  </div>
</div>

<style>
  .image-placeholder {
    width: 100%;
    aspect-ratio: var(--placeholder-ratio);
    min-height: 200px;
    background: linear-gradient(
      145deg,
      var(--color-gray-100) 0%,
      var(--color-gray-50) 50%,
      var(--color-gray-100) 100%
    );
    border: 2px dashed var(--color-gray-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg);
  }

  .image-placeholder__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    text-align: center;
    max-width: 280px;
  }

  .image-placeholder__line {
    display: block;
    width: 100%;
    max-width: 220px;
    height: 2px;
    background-color: var(--color-gray-200);
  }

  .image-placeholder__heading {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-gray-600);
    margin: 0;
  }

  .image-placeholder__filename {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-navy);
    word-break: break-all;
    margin: 0;
    line-height: 1.4;
  }
</style>
