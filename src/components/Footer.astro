---
import footerLogo from "../assets/images/palletman-logo-transparent.png";

const year = new Date().getFullYear();

const dienstenLinks = [
  { label: "Pallets kopen", href: "/pallets-kopen" },
  { label: "Pallets verkopen", href: "/pallets-verkopen" },
  { label: "Europallets", href: "/europallets" },
  { label: "Blokpallets", href: "/blokpallets" },
  { label: "Wegwerppallets", href: "/wegwerppallets" },
  { label: "Ophalen en bezorgen", href: "/werkgebied" },
];

const bedrijfLinks = [
  { label: "Over ons", href: "/over-ons" },
  { label: "Werkgebied", href: "/werkgebied" },
  { label: "Contact", href: "/contact" },
  { label: "FAQ", href: "/faq" },
];

const legalLinks = [
  { label: "Privacy", href: "/privacy" },
  { label: "Cookies", href: "/cookies" },
  { label: "Algemene voorwaarden", href: "/algemene-voorwaarden" },
];

const phoneDisplay = "06 12 34 56 78";
const phoneHref = "+31612345678";
const whatsappHref = "https://wa.me/31612345678";
const email = "info@depalletman.nl";
---

<footer class="footer">
  <div class="footer__main">
    <div class="footer__inner container">
      <div class="footer__grid">
        <div class="footer__col footer__col--brand">
          <a href="/" class="footer__logo" aria-label="De Palletman – naar homepage">
            <img
              src={footerLogo.src}
              width={footerLogo.width}
              height={footerLogo.height}
              alt="De Palletman – De man achter elke pallet"
              class="footer__logo-img"
              loading="lazy"
              decoding="async"
            />
          </a>
          <p class="footer__tagline">
            De Palletman koopt pallets in van bedrijven en particulieren en verkoopt gebruikte
            pallets uitsluitend aan bedrijven. Snel, betrouwbaar en duurzaam.
          </p>
        </div>

        <div class="footer__col">
          <h2 class="footer__heading">Diensten</h2>
          <ul class="footer__links">
            {
              dienstenLinks.map((link) => (
                <li>
                  <a href={link.href} class="footer__link">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="footer__col">
          <h2 class="footer__heading">Bedrijf</h2>
          <ul class="footer__links">
            {
              bedrijfLinks.map((link) => (
                <li>
                  <a href={link.href} class="footer__link">
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="footer__col footer__col--contact">
          <h2 class="footer__heading">Contact</h2>
          <ul class="footer__contact-list">
            <li class="footer__contact-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              <a href={`tel:${phoneHref}`} class="footer__contact-link">{phoneDisplay}</a>
            </li>
            <li class="footer__contact-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                />
              </svg>
              <a
                href={whatsappHref}
                class="footer__whatsapp"
                target="_blank"
                rel="noopener noreferrer"
              >
                WhatsApp
              </a>
            </li>
            <li class="footer__contact-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                <path
                  d="M22 6l-10 7L2 6"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              <a href={`mailto:${email}`} class="footer__contact-link">{email}</a>
            </li>
            <li class="footer__contact-item footer__contact-item--area">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2" />
              </svg>
              <span class="footer__area">
                Werkgebied: Noord-Brabant, Zuid-Holland, Zeeland, Limburg, Utrecht en Gelderland
              </span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <div class="footer__bar">
    <div class="footer__bar-inner container">
      <p class="footer__copy">&copy; {year} De Palletman</p>
      <ul class="footer__legal">
        {
          legalLinks.map((link) => (
            <li>
              <a href={link.href} class="footer__legal-link">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-navy);
    color: var(--color-white);
  }

  .footer__main {
    padding-block: var(--space-3xl) var(--space-2xl);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  .footer__logo {
    display: inline-block;
    margin-bottom: var(--space-lg);
  }

  .footer__logo-img {
    width: auto;
    height: 72px;
    object-fit: contain;
    display: block;
    background: transparent;
  }

  .footer__tagline {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    max-width: 320px;
  }

  .footer__heading {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-lg);
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer__link {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.85);
    transition: color var(--transition-fast);
  }

  .footer__link:hover {
    color: var(--color-gold);
  }

  .footer__contact-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .footer__contact-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.85);
  }

  .footer__contact-item svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-gold);
  }

  .footer__contact-link {
    color: rgba(255, 255, 255, 0.85);
    transition: color var(--transition-fast);
  }

  .footer__contact-link:hover {
    color: var(--color-gold);
  }

  .footer__whatsapp {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    background-color: var(--color-gold);
    color: var(--color-navy);
    font-size: 0.8125rem;
    font-weight: 700;
    border-radius: var(--radius-md);
    transition: background-color var(--transition-fast);
  }

  .footer__whatsapp:hover {
    background-color: var(--color-gold-hover);
  }

  .footer__area {
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
  }

  .footer__bar {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-block: var(--space-md);
    background-color: var(--color-navy-dark);
  }

  .footer__bar-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  .footer__copy {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }

  .footer__legal {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm) var(--space-lg);
  }

  .footer__legal-link {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.65);
    transition: color var(--transition-fast);
  }

  .footer__legal-link:hover {
    color: var(--color-gold);
  }

  @media (min-width: 640px) {
    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-xl) var(--space-2xl);
    }

    .footer__col--brand {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .footer__grid {
      grid-template-columns: 1.3fr 1fr 1fr 1.2fr;
      gap: var(--space-2xl);
    }

    .footer__col--brand {
      grid-column: auto;
    }

    .footer__bar-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }

    .footer__legal {
      justify-content: flex-end;
    }
  }
</style>
