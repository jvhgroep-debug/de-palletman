---
import { HERO_IMAGE_ALT, HERO_IMAGE_PATH } from "../content/shared/heroImage";

interface Props {
  alt?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  class?: string;
}

const {
  alt = HERO_IMAGE_ALT,
  loading = "eager",
  fetchpriority = "high",
  class: className,
} = Astro.props;
---

<img
  src={HERO_IMAGE_PATH}
  alt={alt}
  class:list={["hero-image", className]}
  width="1280"
  height="720"
  loading={loading}
  decoding="async"
  fetchpriority={fetchpriority}
/>

<style>
  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
</style>
