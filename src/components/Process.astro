---
const steps = [
  {
    number: 1,
    title: "Offerte aanvragen",
    description:
      "Bel, app of vraag online een offerte aan. Vertel ons wat u zoekt of wilt verkopen.",
  },
  {
    number: 2,
    title: "Duidelijke offerte",
    description:
      "U ontvangt een heldere prijsopgave op basis van type, aantal en conditie. Geen kleine lettertjes, wel eerlijke tarieven.",
  },
  {
    number: 3,
    title: "Ophalen of bezorgen",
    description:
      "Met eigen transport halen wij pallets op of bezorgen wij bij u op locatie — in Noord-Brabant, Zuid-Holland, Zeeland, Limburg, Utrecht en Gelderland.",
  },
  {
    number: 4,
    title: "Snelle afhandeling",
    description:
      "Verkoopt u pallets? Wij betalen u snel. Koopt u in? Dan leveren wij voortvarend. Afspraak is afspraak.",
  },
];
---

<section class="process" aria-labelledby="process-heading">
  <div class="process__inner container">
    <header class="process__header">
      <p class="process__eyebrow">Onze werkwijze</p>
      <h2 id="process-heading" class="process__title">In vier stappen geregeld</h2>
      <p class="process__intro">
        Van eerste contact tot levering — zo pakken wij het aan.
      </p>
    </header>

    <ol class="process__timeline">
      {
        steps.map((step, index) => (
          <li class="process__step">
            <div class="process__marker" aria-hidden="true">
              <span class="process__number">{step.number}</span>
            </div>
            {index < steps.length - 1 && <span class="process__line" aria-hidden="true"></span>}
            <div class="process__content">
              <h3 class="process__step-title">{step.title}</h3>
              <p class="process__step-text">{step.description}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .process {
    padding-block: var(--space-3xl);
    background-color: var(--color-white);
  }

  .process__header {
    max-width: 640px;
    margin-bottom: var(--space-2xl);
    text-align: center;
    margin-inline: auto;
  }

  .process__eyebrow {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-blue);
    margin-bottom: var(--space-sm);
  }

  .process__title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 800;
    color: var(--color-navy);
    line-height: 1.2;
    margin-bottom: var(--space-md);
  }

  .process__intro {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray-600);
  }

  .process__timeline {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    counter-reset: step;
  }

  .process__step {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .process__marker {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    background-color: var(--color-gold);
    color: var(--color-navy);
    border-radius: var(--radius-full);
    box-shadow: 0 0 0 4px var(--color-white), 0 0 0 6px var(--color-gray-200);
  }

  .process__number {
    font-size: 1.125rem;
    font-weight: 800;
  }

  .process__line {
    display: none;
  }

  .process__step-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: var(--space-sm);
  }

  .process__step-text {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-gray-600);
  }

  @media (min-width: 768px) {
    .process__timeline {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-lg);
    }

    .process__step {
      grid-template-columns: 1fr;
      text-align: center;
      padding-top: var(--space-md);
    }

    .process__marker {
      margin-inline: auto;
      margin-bottom: var(--space-lg);
    }

    .process__line {
      display: block;
      position: absolute;
      top: 38px;
      left: calc(50% + 26px);
      width: calc(100% - 52px);
      height: 3px;
      background: linear-gradient(to right, var(--color-gold), var(--color-blue-light));
      z-index: 1;
    }

    .process__step:last-child .process__line {
      display: none;
    }
  }

  @media (min-width: 1024px) {
    .process__timeline {
      gap: var(--space-xl);
    }
  }
</style>
