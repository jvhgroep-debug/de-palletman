---
const items = [
  {
    title: "Eerlijke prijzen",
    subtitle: "Transparant en marktconform",
    icon: "price",
    variant: "gold",
  },
  {
    title: "Snelle service",
    subtitle: "Ophalen & bezorgen door heel NL",
    icon: "truck",
    variant: "blue",
  },
  {
    title: "Betrouwbaar",
    subtitle: "Afspraken is afspraken",
    icon: "star",
    variant: "gold",
  },
  {
    title: "Duurzaam",
    subtitle: "Hergebruik staat centraal",
    icon: "recycle",
    variant: "blue",
  },
];
---

<section class="usp-bar" aria-label="Onze voordelen">
  <div class="usp-bar__inner container">
    <ul class="usp-bar__list">
      {
        items.map((item) => (
          <li class="usp-bar__item">
            <div
              class:list={[
                "usp-bar__icon",
                item.variant === "gold"
                  ? "usp-bar__icon--gold"
                  : "usp-bar__icon--blue",
              ]}
              aria-hidden="true"
            >
              {item.icon === "price" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <circle cx="7" cy="7" r="1.5" fill="currentColor" />
                </svg>
              )}
              {item.icon === "truck" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <circle cx="5.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="2" />
                  <circle cx="18.5" cy="18.5" r="2.5" stroke="currentColor" stroke-width="2" />
                </svg>
              )}
              {item.icon === "star" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              )}
              {item.icon === "recycle" && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M7 19H4.815a1.83 1.83 0 01-1.57-.881 1.785 1.785 0 01-.004-1.784L7.196 9.5M11 19h8.203a1.83 1.83 0 001.556-.89 1.784 1.784 0 000-1.775l-1.226-2.12M14 5l-2-2-2 2M9.5 8.5L7 5l-2.5 3.5"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M14.5 8.5L17 5l2.5 3.5M7 19l2.5-3.5M17 5v6.5M7 19v-6.5"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              )}
            </div>
            <div class="usp-bar__text">
              <h2 class="usp-bar__title">{item.title}</h2>
              <p class="usp-bar__subtitle">{item.subtitle}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .usp-bar {
    background-color: var(--color-gray-50);
    border-top: 1px solid var(--color-gray-200);
    padding-block: var(--space-xl);
  }

  .usp-bar__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  .usp-bar__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .usp-bar__icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-full);
  }

  .usp-bar__icon--gold {
    background-color: var(--color-gold);
    color: var(--color-navy);
  }

  .usp-bar__icon--blue {
    background-color: var(--color-blue);
    color: var(--color-white);
  }

  .usp-bar__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: var(--space-xs);
    line-height: 1.3;
  }

  .usp-bar__subtitle {
    font-size: 0.875rem;
    color: var(--color-gray-600);
    line-height: 1.4;
  }

  @media (min-width: 640px) {
    .usp-bar__list {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-xl);
    }
  }

  @media (min-width: 1024px) {
    .usp-bar {
      padding-block: var(--space-2xl);
    }

    .usp-bar__list {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-lg);
    }

    .usp-bar__item {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: var(--space-md);
    }

    .usp-bar__icon {
      width: 56px;
      height: 56px;
    }
  }
</style>
