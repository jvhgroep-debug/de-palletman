---
import {
  TRANSPORT_IMAGE_ALT,
  TRANSPORT_IMAGE_PATH,
} from "../content/shared/transportImage";

interface Props {
  alt?: string;
  aspectRatio?: string;
  class?: string;
  loading?: "lazy" | "eager";
}

const {
  alt = TRANSPORT_IMAGE_ALT,
  aspectRatio = "16 / 9",
  class: className,
  loading = "lazy",
} = Astro.props;
---

<div class:list={["transport-image", className]} style={`--transport-image-ratio: ${aspectRatio}`}>
  <img
    class="transport-image__img"
    src={TRANSPORT_IMAGE_PATH}
    alt={alt}
    width="1280"
    height="720"
    loading={loading}
    decoding="async"
  />
</div>

<style>
  .transport-image {
    position: relative;
    width: 100%;
    aspect-ratio: var(--transport-image-ratio);
    min-height: 200px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: linear-gradient(
      145deg,
      var(--color-gray-100) 0%,
      var(--color-gray-50) 50%,
      var(--color-gray-100) 100%
    );
  }

  .transport-image__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
</style>
