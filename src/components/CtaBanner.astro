---
import CtaBannerImage from "./CtaBannerImage.astro";
---

<section class="cta-banner" aria-labelledby="cta-banner-heading">
  <div class="cta-banner__inner container">
    <div class="cta-banner__content">
      <h2 id="cta-banner-heading" class="cta-banner__title">Pallets kopen of verkopen?</h2>
      <p class="cta-banner__text">
        Vraag een offerte aan en ontvang snel een reactie. Wij denken graag mee over de beste
        oplossing voor uw situatie.
      </p>
      <div class="cta-banner__actions">
        <a href="/contact" class="cta-banner__btn cta-banner__btn--primary">
          Offerte aanvragen
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M5 12h14M13 6l6 6-6 6"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
        <a href="/pallets-verkopen" class="cta-banner__btn cta-banner__btn--secondary">
          Pallets verkopen
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M5 12h14M13 6l6 6-6 6"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
        <a href="/pallets-kopen" class="cta-banner__btn cta-banner__btn--secondary">
          Pallets kopen
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M5 12h14M13 6l6 6-6 6"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
      </div>
    </div>

    <div class="cta-banner__media">
      <CtaBannerImage />
    </div>
  </div>
</section>

<style>
  .cta-banner {
    padding-block: var(--space-3xl);
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-navy-dark) 100%);
  }

  .cta-banner__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .cta-banner__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--color-white);
    line-height: 1.15;
    margin-bottom: var(--space-md);
  }

  .cta-banner__text {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-xl);
    max-width: 520px;
  }

  .cta-banner__actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .cta-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    min-height: 3.25rem;
    padding: 1rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: var(--radius-md);
    transition: background-color var(--transition-fast), transform var(--transition-fast),
      border-color var(--transition-fast), color var(--transition-fast);
    text-align: center;
  }

  .cta-banner__btn--primary {
    background-color: var(--color-gold);
    color: var(--color-navy);
  }

  .cta-banner__btn--primary:hover {
    background-color: var(--color-gold-hover);
    transform: translateY(-2px);
  }

  .cta-banner__btn--secondary {
    background-color: transparent;
    color: var(--color-white);
    border: 2px solid var(--color-blue);
  }

  .cta-banner__btn--secondary:hover {
    background-color: var(--color-blue);
    color: var(--color-navy);
    transform: translateY(-2px);
  }

  .cta-banner__btn--whatsapp {
    background-color: var(--color-white);
    color: var(--color-navy);
  }

  .cta-banner__btn--whatsapp:hover {
    background-color: var(--color-gray-100);
    transform: translateY(-2px);
  }

  .cta-banner__media {
    width: 100%;
    max-width: 480px;
    margin-inline: auto;
  }

  @media (min-width: 640px) {
    .cta-banner__actions {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .cta-banner__btn {
      flex: 1 1 auto;
      min-width: 180px;
    }
  }

  @media (min-width: 768px) {
    .cta-banner__inner {
      grid-template-columns: 1.1fr 0.9fr;
      gap: var(--space-3xl);
    }

    .cta-banner__media {
      max-width: none;
      margin-inline: 0;
    }
  }
</style>
