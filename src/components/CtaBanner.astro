---
import ImagePlaceholder from "./ImagePlaceholder.astro";
---

<section class="cta-banner" aria-labelledby="cta-banner-heading">
  <div class="cta-banner__inner container">
    <div class="cta-banner__content">
      <h2 id="cta-banner-heading" class="cta-banner__title">Direct pallets verkopen of kopen?</h2>
      <p class="cta-banner__text">
        Neem vandaag nog contact op en ontvang snel een eerlijke prijsopgave. Wij denken graag met
        u mee.
      </p>
      <div class="cta-banner__actions">
        <a href="/pallets-verkopen" class="cta-banner__btn cta-banner__btn--primary">
          Pallets verkopen
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M5 12h14M13 6l6 6-6 6"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
        <a href="/pallets-kopen" class="cta-banner__btn cta-banner__btn--secondary">
          Pallets kopen
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M5 12h14M13 6l6 6-6 6"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
        <a href="https://wa.me/31612345678" class="cta-banner__btn cta-banner__btn--whatsapp">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            />
          </svg>
          WhatsApp
        </a>
      </div>
    </div>

    <div class="cta-banner__media">
      <ImagePlaceholder filename="cta-pallets.webp" aspectRatio="5 / 4" />
    </div>
  </div>
</section>

<style>
  .cta-banner {
    padding-block: var(--space-3xl);
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-navy-dark) 100%);
  }

  .cta-banner__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .cta-banner__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--color-white);
    line-height: 1.15;
    margin-bottom: var(--space-md);
  }

  .cta-banner__text {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-xl);
    max-width: 520px;
  }

  .cta-banner__actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .cta-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: 1rem 1.5rem;
    font-size: 0.875rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: var(--radius-md);
    transition: background-color var(--transition-fast), transform var(--transition-fast),
      border-color var(--transition-fast), color var(--transition-fast);
    text-align: center;
  }

  .cta-banner__btn--primary {
    background-color: var(--color-gold);
    color: var(--color-navy);
  }

  .cta-banner__btn--primary:hover {
    background-color: var(--color-gold-hover);
    transform: translateY(-2px);
  }

  .cta-banner__btn--secondary {
    background-color: transparent;
    color: var(--color-white);
    border: 2px solid var(--color-blue);
  }

  .cta-banner__btn--secondary:hover {
    background-color: var(--color-blue);
    color: var(--color-navy);
    transform: translateY(-2px);
  }

  .cta-banner__btn--whatsapp {
    background-color: var(--color-white);
    color: var(--color-navy);
  }

  .cta-banner__btn--whatsapp:hover {
    background-color: var(--color-gray-100);
    transform: translateY(-2px);
  }

  .cta-banner__media {
    width: 100%;
    max-width: 480px;
    margin-inline: auto;
  }

  .cta-banner__media :global(.image-placeholder) {
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.06);
  }

  .cta-banner__media :global(.image-placeholder__filename) {
    color: var(--color-white);
  }

  .cta-banner__media :global(.image-placeholder__heading) {
    color: rgba(255, 255, 255, 0.55);
  }

  .cta-banner__media :global(.image-placeholder__line) {
    background-color: rgba(255, 255, 255, 0.2);
  }

  @media (min-width: 640px) {
    .cta-banner__actions {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .cta-banner__btn {
      flex: 1 1 auto;
      min-width: 180px;
    }
  }

  @media (min-width: 768px) {
    .cta-banner__inner {
      grid-template-columns: 1.1fr 0.9fr;
      gap: var(--space-3xl);
    }

    .cta-banner__media {
      max-width: none;
      margin-inline: 0;
    }
  }
</style>
