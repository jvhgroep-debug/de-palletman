---
import ImagePlaceholder from "./ImagePlaceholder.astro";

const usps = [
  "Betrouwbare afspraken — elke keer weer",
  "Scherpe prijzen zonder verrassingen",
  "Persoonlijk contact en korte lijnen",
  "Actief in Zuid- en Midden-Nederland",
  "Offerte op maat, snel in huis",
];
---

<section class="why" aria-labelledby="why-heading">
  <div class="why__inner container">
    <div class="why__content">
      <p class="why__eyebrow">Waarom De Palletman</p>
      <h2 id="why-heading" class="why__title">De partner die bedrijven al jaren verder helpt</h2>
      <p class="why__text">
        Bedrijven in logistiek, productie en handel kiezen voor De Palletman vanwege onze snelheid,
        transparantie en vaste contactpersonen. U weet direct waar u aan toe bent.
      </p>
      <p class="why__text">
        Of u pallets wilt inkopen, een partij wilt afstoten of transport nodig heeft: één telefoontje
        of app is genoeg. Wij regelen de rest.
      </p>
      <ul class="why__list" aria-label="Voordelen van De Palletman">
        {
          usps.map((usp) => (
            <li class="why__item">
              <svg width="18" height="18" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <circle cx="7" cy="7" r="7" fill="currentColor" />
                <path
                  d="M4 7L6 9L10 5"
                  stroke="#0b1d35"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              <span>{usp}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="why__media">
      <ImagePlaceholder filename="over-ons-de-palletman.webp" aspectRatio="4 / 3" />
    </div>
  </div>
</section>

<style>
  .why {
    padding-block: var(--space-3xl);
    background-color: var(--color-gray-50);
  }

  .why__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .why__eyebrow {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-blue);
    margin-bottom: var(--space-sm);
  }

  .why__title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 800;
    color: var(--color-navy);
    line-height: 1.2;
    margin-bottom: var(--space-lg);
  }

  .why__text {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-gray-600);
    margin-bottom: var(--space-md);
  }

  .why__text:last-of-type {
    margin-bottom: var(--space-xl);
  }

  .why__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .why__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-navy);
    line-height: 1.4;
  }

  .why__item svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-gold);
  }

  .why__media {
    width: 100%;
    max-width: 560px;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .why__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }

    .why__media {
      max-width: none;
      margin-inline: 0;
    }
  }
</style>
