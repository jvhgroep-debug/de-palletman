---
const phoneDisplay = "06 12 34 56 78";
const phoneHref = "+31612345678";
const whatsappHref = "https://wa.me/31612345678";
const email = "info@depalletman.nl";
---

<section class="page-contact" aria-label="Contactgegevens">
  <div class="page-contact__inner container">
    <ul class="page-contact__grid">
      <li class="page-contact__card">
        <div class="page-contact__icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path
              d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </div>
        <h3 class="page-contact__label">Telefoon</h3>
        <a href={`tel:${phoneHref}`} class="page-contact__value">{phoneDisplay}</a>
      </li>
      <li class="page-contact__card">
        <div class="page-contact__icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            />
          </svg>
        </div>
        <h3 class="page-contact__label">WhatsApp</h3>
        <a href={whatsappHref} class="page-contact__value page-contact__value--link" target="_blank" rel="noopener noreferrer">
          Stuur een bericht
        </a>
      </li>
      <li class="page-contact__card">
        <div class="page-contact__icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path
              d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <path
              d="M22 6l-10 7L2 6"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </div>
        <h3 class="page-contact__label">E-mail</h3>
        <a href={`mailto:${email}`} class="page-contact__value page-contact__value--link">{email}</a>
      </li>
      <li class="page-contact__card">
        <div class="page-contact__icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path
              d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2" />
          </svg>
        </div>
        <h3 class="page-contact__label">Werkgebied</h3>
        <p class="page-contact__value page-contact__value--text">
          Noord-Brabant, Zuid-Holland, Zeeland, Limburg, Utrecht en Gelderland
        </p>
      </li>
    </ul>

    <div class="page-contact__form-placeholder" aria-label="Contactformulier komt later">
      <p class="page-contact__form-heading">Contactformulier</p>
      <p class="page-contact__form-text">
        Het contactformulier wordt later toegevoegd. Neem voorlopig contact op via telefoon, WhatsApp of
        e-mail.
      </p>
    </div>
  </div>
</section>

<style>
  .page-contact {
    padding-block: var(--space-2xl) var(--space-3xl);
    background-color: var(--color-gray-50);
  }

  .page-contact__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .page-contact__card {
    padding: var(--space-xl);
    background-color: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .page-contact__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    margin-bottom: var(--space-md);
    background-color: var(--color-navy);
    color: var(--color-gold);
    border-radius: var(--radius-md);
  }

  .page-contact__label {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-blue);
    margin-bottom: var(--space-xs);
  }

  .page-contact__value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-navy);
    line-height: 1.5;
  }

  .page-contact__value--link {
    transition: color var(--transition-fast);
  }

  .page-contact__value--link:hover {
    color: var(--color-blue);
  }

  .page-contact__value--text {
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-gray-600);
  }

  .page-contact__form-placeholder {
    padding: var(--space-2xl);
    background-color: var(--color-white);
    border: 2px dashed var(--color-gray-200);
    border-radius: var(--radius-lg);
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
  }

  .page-contact__form-heading {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: var(--space-sm);
  }

  .page-contact__form-text {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-gray-600);
  }

  @media (min-width: 640px) {
    .page-contact__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .page-contact__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
