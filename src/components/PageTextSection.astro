---
interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  id?: string;
  variant?: "gray" | "white";
}

const { eyebrow, title, text, id, variant = "white" } = Astro.props;
---

<section
  class:list={["page-text-section", variant === "gray" && "page-text-section--gray"]}
  aria-labelledby={id}
>
  <div class="page-text-section__inner container">
    {eyebrow && <p class="page-text-section__eyebrow">{eyebrow}</p>}
    <h2 id={id} class="page-text-section__title">{title}</h2>
    <p class="page-text-section__text">{text}</p>
  </div>
</section>

<style>
  .page-text-section {
    padding-block: var(--space-2xl);
    background-color: var(--color-white);
  }

  .page-text-section--gray {
    background-color: var(--color-gray-50);
  }

  .page-text-section__inner {
    max-width: 800px;
  }

  .page-text-section__eyebrow {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-blue);
    margin-bottom: var(--space-sm);
  }

  .page-text-section__title {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 800;
    color: var(--color-navy);
    line-height: 1.25;
    margin-bottom: var(--space-md);
  }

  .page-text-section__text {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-gray-600);
    white-space: pre-line;
  }
</style>
