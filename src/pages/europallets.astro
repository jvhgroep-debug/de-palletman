---
import PageLayout from "../layouts/PageLayout.astro";
import PageHero from "../components/PageHero.astro";
import PageIntro from "../components/PageIntro.astro";
import PageContent from "../components/PageContent.astro";
import PageCta from "../components/PageCta.astro";
---

<PageLayout
  title="Europallets | De Palletman"
  description="Europallets in A- en B-kwaliteit bij De Palletman. Wij leveren uitsluitend aan bedrijven. HT-gestempelde pallets beschikbaar voor export buiten de EU."
  currentPath="/europallets"
>
  <PageHero
    eyebrow="Europallets"
    title="Europallets"
    subtitle="EUR-pallets in A- en B-kwaliteit — betrouwbaar, herbruikbaar en geschikt voor logistiek en export."
    imageFilename="europallets-hero.webp"
  />
  <PageIntro
    eyebrow="Logistieke standaard"
    title="Europallets voor elke toepassing"
    text="Europallets zijn de meest gebruikte pallets in Europa. De Palletman levert Europallets uitsluitend aan bedrijven en koopt Europallets in van bedrijven en particulieren. Ideaal voor transport, opslag en export."
  />
  <PageContent
    columns={2}
    items={[
      {
        title: "A-kwaliteit (Eerste keus)",
        text: "Lichte of blanke pallets met een nette uitstraling. Geschikt wanneer u waarde hecht aan presentatie en een verzorgde conditie.",
      },
      {
        title: "B-kwaliteit (Tweede keus)",
        text: "Donkere gebruikte pallets met normale gebruikssporen maar technisch volledig bruikbaar. Een voordelige keuze voor logistiek en opslag.",
      },
      {
        title: "Verkoop uitsluitend B2B",
        text: "Wij verkopen gebruikte Europallets uitsluitend aan bedrijven. Vraag beschikbaarheid en prijs eenvoudig aan.",
      },
      {
        title: "Inkoop van bedrijven en particulieren",
        text: "Heeft u overtollige Europallets? Wij kopen ze in van bedrijven en particulieren — partijen groot en klein.",
      },
      {
        title: "Export buiten de EU",
        text: "Voor export buiten de Europese Unie zijn HT-gestempelde pallets leverbaar volgens de geldende ISPM 15-richtlijnen.",
      },
      {
        title: "Logistiek en transport",
        text: "Europallets zijn wereldwijd herkenbaar en geschikt voor nationaal en internationaal transport en handel.",
      },
    ]}
  />
  <PageCta
    title="Europallets nodig?"
    text="Vraag beschikbaarheid en prijs eenvoudig aan via contact of WhatsApp."
    primaryLabel="Neem contact op"
    primaryHref="/contact"
    secondaryLabel="Pallets kopen"
    secondaryHref="/pallets-kopen"
  />
</PageLayout>
