---
import PageLayout from "../layouts/PageLayout.astro";
import PageHero from "../components/PageHero.astro";
import PageIntro from "../components/PageIntro.astro";
import PageContent from "../components/PageContent.astro";
import PageCta from "../components/PageCta.astro";
---

<PageLayout
  title="Blokpallets | De Palletman"
  description="Sterke blokpallets voor zware ladingen en industriële toepassingen. Wij leveren uitsluitend aan bedrijven en kopen in van bedrijven en particulieren."
  currentPath="/blokpallets"
>
  <PageHero
    eyebrow="Blokpallets"
    title="Sterke blokpallets"
    subtitle="Voor zware ladingen en industriële toepassingen — robuust, betrouwbaar en duurzaam."
    imageFilename="blokpallets-hero.webp"
  />
  <PageIntro
    eyebrow="Industriële kracht"
    title="Blokpallets voor zware belasting"
    text="Blokpallets zijn ideaal wanneer u zware goederen moet vervoeren of opslaan. De Palletman levert blokpallets uitsluitend aan bedrijven en koopt gebruikte blokpallets in van bedrijven en particulieren. Vraag beschikbaarheid en prijs eenvoudig aan."
  />
  <PageContent
    items={[
      {
        title: "Hoge draagkracht",
        text: "Blokpallets zijn ontworpen voor zware ladingen en industriële toepassingen in magazijnen en productie.",
      },
      {
        title: "Verschillende maten",
        text: "Wij hebben blokpallets in gangbare afmetingen beschikbaar. Informeer naar de actuele voorraad.",
      },
      {
        title: "Herbruikbaar",
        text: "Gebruikte blokpallets zijn een duurzaam en kostenefficiënt alternatief voor nieuwe pallets.",
      },
      {
        title: "Ophalen en bezorgen",
        text: "Wij halen blokpallets op bij bedrijven en particulieren en bezorgen aan bedrijven in ons werkgebied.",
      },
    ]}
  />
  <PageCta
    title="Blokpallets nodig?"
    text="Neem contact op voor beschikbaarheid, prijs en levering in uw regio."
    primaryLabel="Vraag een prijs aan"
    primaryHref="/contact"
    secondaryLabel="Pallets verkopen"
    secondaryHref="/pallets-verkopen"
  />
</PageLayout>
