---
import PageLayout from "../layouts/PageLayout.astro";
import PageHero from "../components/PageHero.astro";
import PageIntro from "../components/PageIntro.astro";
import PageContact from "../components/PageContact.astro";
import PageCta from "../components/PageCta.astro";
---

<PageLayout
  title="Contact | De Palletman"
  description="Neem contact op met De Palletman. Verkoop aan bedrijven, inkoop van bedrijven en particulieren. Bereikbaar via telefoon, WhatsApp en e-mail."
  currentPath="/contact"
>
  <PageHero
    eyebrow="Contact"
    title="Neem contact op"
    subtitle="Vraag een prijsopgave aan of stel uw vraag — wij reageren snel."
  />
  <PageIntro
    eyebrow="Bereikbaar"
    title="Wij staan voor u klaar"
    text="Wilt u pallets verkopen of zoekt u als bedrijf gebruikte pallets? Neem contact op via telefoon, WhatsApp of e-mail. Wij geven u snel een eerlijke prijsopgave en denken graag met u mee."
  />
  <PageContact />
  <PageCta
    title="Liever direct WhatsApp?"
    text="Stuur ons een bericht met type, aantal en conditie van uw pallets — wij reageren zo snel mogelijk."
    primaryLabel="WhatsApp"
    primaryHref="https://wa.me/31612345678"
    secondaryLabel="Veelgestelde vragen"
    secondaryHref="/faq"
  />
</PageLayout>
