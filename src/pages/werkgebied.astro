---
import PageLayout from "../layouts/PageLayout.astro";
import PageHero from "../components/PageHero.astro";
import PageIntro from "../components/PageIntro.astro";
import PageRegions from "../components/PageRegions.astro";
import PageCta from "../components/PageCta.astro";

const regions = [
  {
    name: "Noord-Brabant",
    text: "Pallets kopen en verkopen in Noord-Brabant. Ophalen bij bedrijven en particulieren, bezorgen uitsluitend aan bedrijven.",
    href: "/noord-brabant",
  },
  {
    name: "Zuid-Holland",
    text: "Gebruikte pallets in Zuid-Holland — van Rotterdam tot Den Haag. Europallets, blokpallets en wegwerppallets.",
    href: "/zuid-holland",
  },
  {
    name: "Zeeland",
    text: "Palletservice in Zeeland. Inkoop bij bedrijven en particulieren, levering aan bedrijven met eigen transport.",
    href: "/zeeland",
  },
  {
    name: "Limburg",
    text: "In- en verkoop van gebruikte pallets in Limburg. A- en B-kwaliteit europallets, ook HT-gestempeld voor export.",
    href: "/limburg",
  },
  {
    name: "Utrecht",
    text: "Pallets kopen, verkopen en laten ophalen in Utrecht. Grote én kleine partijen welkom.",
    href: "/utrecht",
  },
  {
    name: "Gelderland",
    text: "Gebruikte pallets in Gelderland — ophalen, bezorgen en eerlijke prijzen voor bedrijven en particulieren.",
    href: "/gelderland",
  },
];
---

<PageLayout
  title="Werkgebied | De Palletman"
  description="De Palletman is actief in Noord-Brabant, Zuid-Holland, Zeeland, Limburg, Utrecht en Gelderland. Ophalen bij bedrijven en particulieren, bezorgen aan bedrijven."
  currentPath="/werkgebied"
>
  <PageHero
    eyebrow="Werkgebied"
    title="Actief in heel Zuid- en Midden-Nederland"
    subtitle="Ophalen bij bedrijven en particulieren · Bezorgen uitsluitend aan bedrijven."
    imageFilename="werkgebied-hero.webp"
  />
  <PageIntro
    eyebrow="Onze regio"
    title="Waar wij actief zijn"
    text="De Palletman is actief in Noord-Brabant, Zuid-Holland, Zeeland, Limburg, Utrecht en Gelderland. Klik op een provincie voor meer informatie over ophalen, bezorgen en onze palletdiensten in uw regio."
  />
  <PageRegions regions={regions} />
  <PageCta
    title="Actief in uw regio?"
    text="Neem contact op en vraag naar ophalen, bezorgen of een prijsopgave voor uw regio."
    primaryLabel="Neem contact op"
    primaryHref="/contact"
    secondaryLabel="Pallets verkopen"
    secondaryHref="/pallets-verkopen"
  />
</PageLayout>
