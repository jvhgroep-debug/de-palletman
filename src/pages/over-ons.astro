---
import PageLayout from "../layouts/PageLayout.astro";
import PageHero from "../components/PageHero.astro";
import PageIntro from "../components/PageIntro.astro";
import PageContent from "../components/PageContent.astro";
import PageCta from "../components/PageCta.astro";
---

<PageLayout
  title="Over ons | De Palletman"
  description="Leer De Palletman kennen: dé specialist in gebruikte pallets. Snel, betrouwbaar en duurzaam voor bedrijven en particulieren."
  currentPath="/over-ons"
>
  <PageHero
    eyebrow="Over ons"
    title="De man achter elke pallet"
    subtitle="De Palletman koopt en verkoopt gebruikte pallets — snel, betrouwbaar en duurzaam."
    imageFilename="over-ons-hero.webp"
  />
  <PageIntro
    eyebrow="Wie wij zijn"
    title="Specialist in gebruikte pallets"
    text="De Palletman is uw partner voor het kopen en verkopen van gebruikte pallets. Wij bedienen bedrijven en particulieren in een groot deel van Nederland. Met eerlijke prijzen, snelle afhandeling en persoonlijke service maken wij palletbeheer eenvoudig."
  />
  <PageContent
    items={[
      {
        title: "Onze missie",
        text: "Wij geven gebruikte pallets een tweede leven. Door in- en verkoop te faciliteren dragen wij bij aan circulair gebruik van hout en verminderen wij afval.",
      },
      {
        title: "Onze aanpak",
        text: "Transparant, snel en betrouwbaar. Wij geven eerlijke prijsopgaven, reageren snel op aanvragen en regelen ophalen of bezorgen waar nodig.",
      },
      {
        title: "Voor wie",
        text: "Van kleine particulieren tot grote bedrijven — wij helpen iedereen die pallets wil kopen, verkopen of hergebruiken.",
      },
      {
        title: "Ons werkgebied",
        text: "Wij zijn actief in Noord-Brabant, Zuid-Holland, Zeeland, Limburg, Utrecht en Gelderland. Bekijk ons werkgebied voor meer informatie.",
      },
    ]}
  />
  <PageCta
    title="Kennismaken?"
    text="Neem contact op en ontdek wat De Palletman voor u kan betekenen."
    primaryLabel="Neem contact op"
    primaryHref="/contact"
    secondaryLabel="Bekijk werkgebied"
    secondaryHref="/werkgebied"
  />
</PageLayout>
