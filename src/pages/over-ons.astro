---
import PageLayout from "../layouts/PageLayout.astro";
import PageHero from "../components/PageHero.astro";
import PageIntro from "../components/PageIntro.astro";
import PageContent from "../components/PageContent.astro";
import PageCta from "../components/PageCta.astro";
---

<PageLayout
  title="Over ons | De Palletman"
  description="Leer De Palletman kennen: dé specialist in gebruikte pallets. Verkoop uitsluitend B2B, inkoop van bedrijven en particulieren."
  currentPath="/over-ons"
>
  <PageHero
    eyebrow="Over ons"
    title="De man achter elke pallet"
    subtitle="Inkoop van bedrijven en particulieren · Verkoop uitsluitend aan bedrijven."
  />
  <PageIntro
    eyebrow="Wie wij zijn"
    title="Specialist in gebruikte pallets"
    text="De Palletman is uw partner voor palletbeheer in een groot deel van Nederland. Wij verkopen gebruikte pallets uitsluitend aan bedrijven en kopen in van bedrijven en particulieren. Met eerlijke prijzen, snelle afhandeling en persoonlijke service maken wij het eenvoudig."
  />
  <PageContent
    items={[
      {
        title: "Onze missie",
        text: "Wij geven gebruikte pallets een tweede leven. Door in- en verkoop te faciliteren dragen wij bij aan circulair gebruik van hout en verminderen wij afval.",
      },
      {
        title: "Onze aanpak",
        text: "Transparant, snel en betrouwbaar. Wij geven eerlijke prijsopgaven, reageren snel op aanvragen en regelen ophalen of bezorgen waar nodig.",
      },
      {
        title: "Voor wie",
        text: "Wij verkopen gebruikte pallets uitsluitend aan bedrijven. Pallets inkopen wij van bedrijven en particulieren — van kleine partijen tot grote volumes.",
      },
      {
        title: "Ons werkgebied",
        text: "Wij zijn actief in Noord-Brabant, Zuid-Holland, Zeeland, Limburg, Utrecht en Gelderland. Bekijk ons werkgebied voor meer informatie.",
      },
    ]}
  />
  <PageCta
    title="Kennismaken?"
    text="Neem contact op en ontdek wat De Palletman voor u kan betekenen."
    primaryLabel="Neem contact op"
    primaryHref="/contact"
    secondaryLabel="Bekijk werkgebied"
    secondaryHref="/werkgebied"
  />
</PageLayout>
